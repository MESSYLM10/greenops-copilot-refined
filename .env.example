# GreenOps Copilot — local development environment
# Copy to .env and fill in values. Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GEMINI_API_KEY=your-gemini-api-key

# ── Carbon data provider (choose one tier) ────────────────────────────────────
# Tier 1 — WattTime (recommended, free, immediate key at watttime.org/sign-up)
WATTTIME_USERNAME=
WATTTIME_PASSWORD=

# Tier 2 — Electricity Maps (free tier at electricitymaps.com/free-tier-api)
ELECTRICITY_MAPS_API_KEY=

# Tier 3 — Simulation (no key needed — set CARBON_PROVIDER=simulation)
# CARBON_PROVIDER=simulation

# Leave CARBON_PROVIDER blank for auto-detection (uses whichever keys are set)
CARBON_PROVIDER=

# ── Optional overrides (defaults shown) ───────────────────────────────────────
PRIMARY_REGION=us-central1
GREEN_REGIONS=europe-west1,europe-north1,us-west1,europe-west4,us-central1,asia-east1
GEMINI_MODEL=gemini-2.0-flash-exp
BIGQUERY_DATASET=greenops_carbon
FIRESTORE_COLLECTION=sessions
ALERT_TOPIC=greenops-green-window-alerts

# ── Frontend ──────────────────────────────────────────────────────────────────
REACT_APP_ORCHESTRATOR_URL=http://localhost:8080
